# Copy to .env and fill in (optional — only for Google Sign-In).
# Use underscores: EXPO_PUBLIC_...  (not EXPO-PUBLIC-...)
# Restart Metro after changing: npx expo start -c

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional — Profile (dev) Push/Pull data/*.json via GitHub Contents API (classic PAT with repo scope).
# EXPO_PUBLIC_ is bundled; use a dev-only token. Or set expo.extra.githubToken / githubRepo in app.json.
EXPO_PUBLIC_GITHUB_TOKEN=
EXPO_PUBLIC_GITHUB_REPO=
EXPO_PUBLIC_GITHUB_BRANCH=main
