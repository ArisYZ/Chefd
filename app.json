{
  "expo": {
    "name": "Chef'd",
    "slug": "chefd",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "chefd",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2D5A3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chefd.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D5A3D"
      },
      "package": "com.chefd.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Chef'd to access your photos to add recipe images.",
          "cameraPermission": "Allow Chef'd to use your camera to take recipe photos."
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {},
    "extra": {
      "googleWebClientId": "",
      "googleIosClientId": "",
      "googleAndroidClientId": ""
    }
  }
}
